// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model files {
  file_id             String          @id @default(uuid())
  file_uploaded_by_id String?
  file_listing_id     String?  
  file_upload_type    String
  file_is_deleted     Boolean
  file_media_type     file_media_type
  file_url            String          @db.LongText
  file_created_at     DateTime        @default(now())
  file_updated_at     DateTime        @updatedAt
  file_thumbnail_url  String?

  @@index(fields: [file_id])
  @@index([file_listing_id]) // ✅ add index

}

enum file_media_type {
  image
  video
  audio
  pdf
  text
  doc
}
